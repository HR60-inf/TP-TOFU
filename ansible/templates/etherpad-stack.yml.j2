version: '3.8'

services:
  etherpad:
    image: etherpad/etherpad:latest
    networks:
      - traefik-public
    environment:
      - NODE_ENV=production
      - DB_TYPE=dirty
    volumes:
      - type: bind
        source: /var/nfs/etherpad_data
        target: /opt/etherpad-lite/var
    healthcheck:
      disable: true
    deploy:
      replicas: 1
      placement:
        constraints:
          - node.role == manager
      labels:
        - "traefik.enable=true"
        - "traefik.http.routers.etherpad.entrypoints=web"
        - "traefik.http.routers.etherpad.rule=Host(`pad.{{ ansible_host }}.sslip.io`)"
        - "traefik.http.services.etherpad.loadbalancer.server.port=9001"

networks:
  traefik-public:
    external: true
